{
  "title": "Podinfo Dashboard",
  "uid": "podinfo-dashboard",
  "schemaVersion": 38,
  "version": 1,
  "panels": [
    {
      "id": 1,
      "title": "RPS",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "targets": [{
        "expr": "sum(rate(http_requests_total{namespace=\"podinfo-dev\"}[5m]))",
        "legendFormat": "RPS"
      }]
    },
    {
      "id": 2,
      "title": "p95 Latency",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "targets": [{
        "expr": "histogram_quantile(0.95, sum by (le) (rate(http_request_duration_seconds_bucket{namespace=\"podinfo-dev\"}[5m])))",
        "legendFormat": "p95"
      }]
    },
    {
      "id": 3,
      "title": "Error Rate (5xx %)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "targets": [{
        "expr": "sum(rate(http_requests_total{namespace=\"podinfo-dev\",status=~\"5..\"}[5m])) / sum(rate(http_requests_total{namespace=\"podinfo-dev\"}[5m])) * 100",
        "legendFormat": "5xx %"
      }]
    },
    {
      "id": 4,
      "title": "Replicas",
      "type": "stat",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "targets": [{
        "expr": "kube_deployment_status_replicas_available{namespace=\"podinfo-dev\"}",
        "legendFormat": "Available replicas"
      }]
    }
  ],
  "time": {"from": "now-1h", "to": "now"},
  "refresh": "30s"
}
